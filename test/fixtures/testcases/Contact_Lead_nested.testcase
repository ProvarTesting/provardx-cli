<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<testCase guid="1806c8a5-103d-4255-9c23-2fc150293224" id="1" registryId="e7b1c2d3-4f56-4789-abcd-ef9876543210">
  <summary>Creates a Lead record in Salesforce via the Lightning UI using the DogfoodingOrg connection. Generates unique LastName and Company values, logs in through ApexConnect, navigates to the Leads list view, clicks New, populates the required fields (LastName and Company), clicks Save, then asserts that the resulting Lead record page shows the same LastName and Company values that were entered. autoCleanup=true on ApexConnect handles record teardown after the run.</summary>
  <steps>
    <apiCall apiId="com.provar.plugins.bundled.apis.control.SetValues" guid="99c474d5-4776-4c20-9e4b-9e690fb8d2f8" name="Set test data variables" testItemId="1" title="Set test data variables">
      <arguments>
        <argument id="values">
          <value class="valueList" mutable="Mutable">
            <namedValues mutable="Mutable">
              <namedValue name="valuePath">
                <value class="value" valueClass="string">leadLastName</value>
              </namedValue>
              <namedValue name="value">
                <value class="compound">
                  <parts>
                    <value valueClass="string">Provar_TestLead_</value>
                    <funcCall id="UniqueId">
                      <argument id="length">
                        <value class="value" valueClass="decimal">6</value>
                      </argument>
                    </funcCall>
                  </parts>
                </value>
              </namedValue>
              <namedValue name="valueScope">
                <value class="value" valueClass="string">Test</value>
              </namedValue>
            </namedValues>
            <namedValues mutable="Mutable">
              <namedValue name="valuePath">
                <value class="value" valueClass="string">leadCompany</value>
              </namedValue>
              <namedValue name="value">
                <value class="compound">
                  <parts>
                    <value valueClass="string">Provar Test Company </value>
                    <funcCall id="UniqueId">
                      <argument id="length">
                        <value class="value" valueClass="decimal">6</value>
                      </argument>
                    </funcCall>
                  </parts>
                </value>
              </namedValue>
              <namedValue name="valueScope">
                <value class="value" valueClass="string">Test</value>
              </namedValue>
            </namedValues>
          </value>
        </argument>
      </arguments>
    </apiCall>
    <apiCall apiId="com.provar.plugins.forcedotcom.core.testapis.ApexConnect" guid="8257eba7-d17a-45c5-a7a2-1c17a8044514" name="Salesforce Connect: DogfoodingOrg (Sales app)" testItemId="2" title="Salesforce Connect: DogfoodingOrg (Test)">
      <arguments>
        <argument id="connectionName">
          <value class="value" valueClass="string">DogfoodingOrg</value>
        </argument>
        <argument id="resultName">
          <value class="value" valueClass="string">DogfoodingOrg</value>
        </argument>
        <argument id="resultScope">
          <value class="value" valueClass="string">Test</value>
        </argument>
        <argument id="uiApplicationName">
          <value class="value" valueClass="string">LightningSales</value>
        </argument>
        <argument id="quickUiLogin">
          <value class="value" valueClass="boolean">true</value>
        </argument>
        <argument id="closeAllPrimaryTabs">
          <value class="value" valueClass="boolean">true</value>
        </argument>
        <argument id="alreadyOpenBehaviour">
          <value class="value" valueClass="string">Reuse</value>
        </argument>
        <argument id="enableObjectIdLogging">
          <value class="value" valueClass="boolean">true</value>
        </argument>
        <argument id="autoCleanup">
          <value class="value" valueClass="boolean">true</value>
        </argument>
        <argument id="lightningMode">
          <value class="value" valueClass="string">default</value>
        </argument>
        <argument id="connectionId">
          <value class="value" valueClass="id">dc6b587f-d62b-4b7d-9a34-ab6abe501c11</value>
        </argument>
        <argument id="reuseConnectionName"/>
        <argument id="privateBrowsingMode"/>
        <argument id="cleanupConnectionName"/>
        <argument id="logFileLocation"/>
        <argument id="username"/>
        <argument id="password"/>
        <argument id="securityToken"/>
        <argument id="environment"/>
        <argument id="webBrowser"/>
      </arguments>
    </apiCall>
    <apiCall apiId="com.provar.plugins.forcedotcom.core.ui.UiWithScreen" guid="fe0c7294-8279-4b71-ac72-d415e6594b47" name="On SF Leads list view - click New" testItemId="3" title="On SF Leads list view - click New">
      <arguments>
        <argument id="uiConnectionName">
          <value class="value" valueClass="string">DogfoodingOrg</value>
        </argument>
        <argument id="target">
          <value class="uiTarget" uri="sf:ui:target?object=Lead&amp;page=list"/>
        </argument>
        <argument id="navigate">
          <value class="value" valueClass="string">Always</value>
        </argument>
        <argument id="targetDescription">
          <value class="value" valueClass="string">On SF Leads list view - click New</value>
        </argument>
        <argument id="windowSelection">
          <value class="value" valueClass="string">Default</value>
        </argument>
        <argument id="windowSize">
          <value class="value" valueClass="string">Default</value>
        </argument>
        <argument id="closeWindow"/>
        <argument id="captureBefore">
          <value class="value" valueClass="boolean">false</value>
        </argument>
        <argument id="captureAfter">
          <value class="value" valueClass="boolean">false</value>
        </argument>
        <argument id="sfUiTargetVfIndex">
          <value class="value" valueClass="string">1</value>
        </argument>
      </arguments>
      <clauses>
        <clause name="substeps" testItemId="4">
          <steps>
            <apiCall apiId="com.provar.plugins.forcedotcom.core.ui.UiDoAction" guid="dfa079f8-4e9c-4988-a06f-582fa095c10a" name="Click the New button" testItemId="5" title="Click the New button">
              <arguments>
                <argument id="locator">
                  <value class="value" valueClass="string">ui:locator?name=New</value>
                </argument>
                <argument id="interaction">
                  <value class="value" valueClass="string">ui:interaction?name=click</value>
                </argument>
                <argument id="interactionDescription">
                  <value class="value" valueClass="string">Click the New button</value>
                </argument>
                <argument id="captureBefore">
                  <value class="value" valueClass="boolean">false</value>
                </argument>
                <argument id="captureAfter">
                  <value class="value" valueClass="boolean">false</value>
                </argument>
              </arguments>
            </apiCall>
          </steps>
        </clause>
      </clauses>
      <generatedParameters>
        <apiParam group="target" name="sfUiTargetVfIndex" title="Page Index">
          <summary>The VF page index. This is by default 1 and is used when there is same VF embedded multiple times</summary>
          <type>
            <numericType/>
          </type>
        </apiParam>
      </generatedParameters>
    </apiCall>
    <apiCall apiId="com.provar.plugins.forcedotcom.core.ui.UiWithScreen" guid="613a6da0-4298-48f0-9c35-3d777eb5b491" name="On SF New Lead form - fill required fields and Save" testItemId="6" title="On SF New Lead form - fill required fields and Save">
      <arguments>
        <argument id="uiConnectionName">
          <value class="value" valueClass="string">DogfoodingOrg</value>
        </argument>
        <argument id="target">
          <value class="uiTarget" uri="sf:ui:target?object=Lead&amp;action=New"/>
        </argument>
        <argument id="navigate">
          <value class="value" valueClass="string">Dont</value>
        </argument>
        <argument id="sfUiTargetResultName">
          <value class="value" valueClass="string">LeadId</value>
        </argument>
        <argument id="targetDescription">
          <value class="value" valueClass="string">On SF New Lead form - fill required fields and Save</value>
        </argument>
        <argument id="windowSelection">
          <value class="value" valueClass="string">Default</value>
        </argument>
        <argument id="windowSize">
          <value class="value" valueClass="string">Default</value>
        </argument>
        <argument id="closeWindow"/>
        <argument id="captureBefore">
          <value class="value" valueClass="boolean">false</value>
        </argument>
        <argument id="captureAfter">
          <value class="value" valueClass="boolean">false</value>
        </argument>
      </arguments>
      <clauses>
        <clause name="substeps" testItemId="7">
          <steps>
            <apiCall apiId="com.provar.plugins.forcedotcom.core.ui.UiDoAction" guid="e2e5bbab-aa8b-404a-bef7-6545122f21bf" name="Set the Last Name field" testItemId="8" title="Set the Last Name field">
              <arguments>
                <argument id="locator">
                  <value class="value" valueClass="string">ui:locator?name=LastName</value>
                </argument>
                <argument id="interaction">
                  <value class="value" valueClass="string">ui:interaction?name=set</value>
                </argument>
                <argument id="value">
                  <value class="variable">
                    <path element="leadLastName"/>
                  </value>
                </argument>
                <argument id="interactionDescription">
                  <value class="value" valueClass="string">Set the Last Name field to {leadLastName}</value>
                </argument>
                <argument id="captureBefore">
                  <value class="value" valueClass="boolean">false</value>
                </argument>
                <argument id="captureAfter">
                  <value class="value" valueClass="boolean">false</value>
                </argument>
              </arguments>
            </apiCall>
            <apiCall apiId="com.provar.plugins.forcedotcom.core.ui.UiDoAction" guid="ba5a0d34-9ffc-4be6-ae0d-7c0e7ee2bced" name="Set the Company field" testItemId="9" title="Set the Company field">
              <arguments>
                <argument id="locator">
                  <value class="value" valueClass="string">ui:locator?name=Company</value>
                </argument>
                <argument id="interaction">
                  <value class="value" valueClass="string">ui:interaction?name=set</value>
                </argument>
                <argument id="value">
                  <value class="variable">
                    <path element="leadCompany"/>
                  </value>
                </argument>
                <argument id="interactionDescription">
                  <value class="value" valueClass="string">Set the Company field to {leadCompany}</value>
                </argument>
                <argument id="captureBefore">
                  <value class="value" valueClass="boolean">false</value>
                </argument>
                <argument id="captureAfter">
                  <value class="value" valueClass="boolean">false</value>
                </argument>
              </arguments>
            </apiCall>
            <apiCall apiId="com.provar.plugins.forcedotcom.core.ui.UiDoAction" guid="e59f2d1b-afaf-467e-bbbf-6135af3bc89d" name="Click the Save button" testItemId="10" title="Click the Save button">
              <arguments>
                <argument id="locator">
                  <value class="value" valueClass="string">ui:locator?name=SaveEdit</value>
                </argument>
                <argument id="interaction">
                  <value class="value" valueClass="string">ui:interaction?name=click</value>
                </argument>
                <argument id="interactionDescription">
                  <value class="value" valueClass="string">Click the Save button</value>
                </argument>
                <argument id="captureBefore">
                  <value class="value" valueClass="boolean">false</value>
                </argument>
                <argument id="captureAfter">
                  <value class="value" valueClass="boolean">false</value>
                </argument>
              </arguments>
            </apiCall>
          </steps>
        </clause>
      </clauses>
    </apiCall>
    <apiCall apiId="com.provar.plugins.forcedotcom.core.ui.UiWithScreen" guid="556b06bb-2204-4134-b305-b3883753cf91" name="On SF Lead record page - assert detail fields" testItemId="11" title="On SF Lead record page - assert detail fields">
      <arguments>
        <argument id="uiConnectionName">
          <value class="value" valueClass="string">DogfoodingOrg</value>
        </argument>
        <argument id="target">
          <value class="uiTarget" uri="sf:ui:target?object=Lead&amp;action=View"/>
        </argument>
        <argument id="navigate">
          <value class="value" valueClass="string">Dont</value>
        </argument>
        <argument id="sfUiTargetObjectId">
          <value class="variable">
            <path element="LeadId"/>
          </value>
        </argument>
        <argument id="targetDescription">
          <value class="value" valueClass="string">On SF Lead record page - assert detail fields</value>
        </argument>
        <argument id="windowSelection">
          <value class="value" valueClass="string">Default</value>
        </argument>
        <argument id="windowSize">
          <value class="value" valueClass="string">Default</value>
        </argument>
        <argument id="closeWindow"/>
        <argument id="captureBefore">
          <value class="value" valueClass="boolean">false</value>
        </argument>
        <argument id="captureAfter">
          <value class="value" valueClass="boolean">false</value>
        </argument>
      </arguments>
      <clauses>
        <clause name="substeps" testItemId="12">
          <steps>
            <apiCall apiId="com.provar.plugins.forcedotcom.core.ui.UiAssert" guid="8b5263cf-bb52-4d0f-8b8d-c8c9dd9e0399" name="Assert Last Name field value" testItemId="13" title="Assert Last Name field value">
              <arguments>
                <argument id="resultName">
                  <value class="value" valueClass="string">Values</value>
                </argument>
                <argument id="resultScope">
                  <value class="value" valueClass="string">Test</value>
                </argument>
                <argument id="fieldAssertions">
                  <value class="valueList" mutable="Mutable">
                    <uiFieldAssertion resultName="LastName">
                      <fieldLocator uri="ui:locator?name=LastName"/>
                      <attributeAssertions>
                        <uiAttributeAssertion attributeName="value" comparisonType="EqualTo">
                          <value class="variable">
                            <path element="leadLastName"/>
                          </value>
                        </uiAttributeAssertion>
                      </attributeAssertions>
                    </uiFieldAssertion>
                  </value>
                </argument>
                <argument id="captureAfter">
                  <value class="value" valueClass="boolean">false</value>
                </argument>
                <argument id="columnAssertions">
                  <value class="valueList" mutable="Mutable"/>
                </argument>
                <argument id="pageAssertions">
                  <value class="valueList" mutable="Mutable"/>
                </argument>
                <argument id="beforeWait"/>
                <argument id="autoRetry"/>
              </arguments>
            </apiCall>
            <apiCall apiId="com.provar.plugins.forcedotcom.core.ui.UiAssert" guid="22a54a68-46fa-4ec4-8420-5a7220f0daf0" name="Assert Company field value" testItemId="14" title="Assert Company field value">
              <arguments>
                <argument id="resultName">
                  <value class="value" valueClass="string">Values</value>
                </argument>
                <argument id="resultScope">
                  <value class="value" valueClass="string">Test</value>
                </argument>
                <argument id="fieldAssertions">
                  <value class="valueList" mutable="Mutable">
                    <uiFieldAssertion resultName="Company">
                      <fieldLocator uri="ui:locator?name=Company"/>
                      <attributeAssertions>
                        <uiAttributeAssertion attributeName="value" comparisonType="EqualTo">
                          <value class="variable">
                            <path element="leadCompany"/>
                          </value>
                        </uiAttributeAssertion>
                      </attributeAssertions>
                    </uiFieldAssertion>
                  </value>
                </argument>
                <argument id="captureAfter">
                  <value class="value" valueClass="boolean">false</value>
                </argument>
                <argument id="columnAssertions">
                  <value class="valueList" mutable="Mutable"/>
                </argument>
                <argument id="pageAssertions">
                  <value class="valueList" mutable="Mutable"/>
                </argument>
                <argument id="beforeWait"/>
                <argument id="autoRetry"/>
              </arguments>
            </apiCall>
          </steps>
        </clause>
      </clauses>
    </apiCall>
  </steps>
</testCase>
